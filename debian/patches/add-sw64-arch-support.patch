From: lichenggang <lichenggang@uniontech.com>
Date: Mon, 13 Jul 2026 17:30:00 +0800
Subject: Add sw64 (Sunway) architecture support

Add sw64 architecture support for bpftrace on Sunway processors.

This patch:
- Adds src/arch/sw64.cpp with register definitions for the sw64
  architecture, based on the Linux kernel pt_regs structure for arch/sw_64
- Updates src/arch/CMakeLists.txt to recognize sw_64 as the cmake
  system processor for the sw64 architecture

The sw64 architecture uses:
- 31 general-purpose registers (r0-r30)
- Register r16-r21 (a0-a5) for function arguments (following the calling
  convention defined in asm/regdef.h)
- r0 (v0) for return value, r30 (sp) as stack pointer
- pc for program counter, pstate for processor state
- 64-bit kernel pointers

Signed-off-by: lichenggang <lichenggang@uniontech.com>
---
--- a/src/arch/CMakeLists.txt
+++ b/src/arch/CMakeLists.txt
@@ -14,6 +14,8 @@ elseif(CMAKE_SYSTEM_PROCESSOR STREQUAL "riscv64")
     add_library(arch STATIC riscv64.cpp)
 elseif(CMAKE_SYSTEM_PROCESSOR STREQUAL "loongarch64")
     add_library(arch STATIC loongarch64.cpp)
+elseif(CMAKE_SYSTEM_PROCESSOR STREQUAL "sw_64")
+    add_library(arch STATIC sw64.cpp)
 else()
   message(FATAL_ERROR "Unsupported architecture: ${CMAKE_SYSTEM_PROCESSOR}")
 endif()
new file mode 100644
--- /dev/null
+++ b/src/arch/sw64.cpp
@@ -0,0 +1,157 @@
+#include "arch.h"
+#include "utils.h"
+
+#include <algorithm>
+#include <array>
+
+// SP points to the first argument that is passed on the stack
+#define ARG0_STACK 0
+
+namespace bpftrace {
+namespace arch {
+
+// clang-format off
+static std::array<std::string, 33> registers = {
+  "r0",
+  "r1",
+  "r2",
+  "r3",
+  "r4",
+  "r5",
+  "r6",
+  "r7",
+  "r8",
+  "r9",
+  "r10",
+  "r11",
+  "r12",
+  "r13",
+  "r14",
+  "r15",
+  "r16",
+  "r17",
+  "r18",
+  "r19",
+  "r20",
+  "r21",
+  "r22",
+  "r23",
+  "r24",
+  "r25",
+  "r26",
+  "r27",
+  "r28",
+  "r29",
+  "r30",
+  "pc",
+  "pstate",
+};
+
+// Alternative register names that match struct pt_regs
+static std::array<std::string, 33> ptrace_registers = {
+  "regs[0]",
+  "regs[1]",
+  "regs[2]",
+  "regs[3]",
+  "regs[4]",
+  "regs[5]",
+  "regs[6]",
+  "regs[7]",
+  "regs[8]",
+  "regs[9]",
+  "regs[10]",
+  "regs[11]",
+  "regs[12]",
+  "regs[13]",
+  "regs[14]",
+  "regs[15]",
+  "regs[16]",
+  "regs[17]",
+  "regs[18]",
+  "regs[19]",
+  "regs[20]",
+  "regs[21]",
+  "regs[22]",
+  "regs[23]",
+  "regs[24]",
+  "regs[25]",
+  "regs[26]",
+  "regs[27]",
+  "regs[28]",
+  "regs[29]",
+  "regs[30]",
+  "pc",
+  "pstate",
+};
+
+static std::array<std::string, 6> arg_registers = {
+  "r16",
+  "r17",
+  "r18",
+  "r19",
+  "r20",
+  "r21",
+};
+// clang-format on
+
+int offset(std::string reg_name)
+{
+  auto it = find(registers.begin(), registers.end(), reg_name);
+  if (it == registers.end()) {
+    it = find(ptrace_registers.begin(), ptrace_registers.end(), reg_name);
+    if (it == ptrace_registers.end()) {
+      return -1;
+    }
+    return distance(ptrace_registers.begin(), it);
+  }
+  return distance(registers.begin(), it);
+}
+
+int max_arg()
+{
+  return arg_registers.size() - 1;
+}
+
+int arg_offset(int arg_num)
+{
+  return offset(arg_registers.at(arg_num));
+}
+
+int pc_offset()
+{
+  return offset("pc");
+}
+
+int ret_offset()
+{
+  return offset("r0");
+}
+
+int sp_offset()
+{
+  return offset("r30");
+}
+
+int arg_stack_offset()
+{
+  return ARG0_STACK / 8;
+}
+
+std::string name()
+{
+  return std::string("sw64");
+}
+
+std::vector<std::string> invalid_watchpoint_modes()
+{
+  throw FatalUserException(
+      "Watchpoints are not supported on this architecture");
+}
+
+int get_kernel_ptr_width()
+{
+  return 64;
+}
+
+} // namespace arch
+} // namespace bpftrace

